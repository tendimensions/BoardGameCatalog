# =============================================================================
# Board Game Catalog — Environment Variables
# =============================================================================
#
# PRODUCTION (Linode server):
#   Location: ~/boardgames/.env   ← same directory as docker-compose.yml
#   The Docker container reads this file via "env_file: - .env" in
#   docker-compose.yml.
#
# LOCAL DEVELOPMENT:
#   Location: web/.env   ← same directory as docker-compose.yml and manage.py
#   Run "python manage.py runserver" from the web/ directory.
#
# To create your production .env on the server:
#   ssh user@<linode-ip>
#   cp ~/boardgames/.env.example ~/boardgames/.env
#   nano ~/boardgames/.env
#
# =============================================================================


# =============================================================================
# SECTION 1 — Django Core  (REQUIRED)
# =============================================================================

# Secret key for cryptographic signing. Must be long, random, and unique.
# Generate one with:
#   python -c "import secrets; print(secrets.token_hex(50))"
#
SECRET_KEY=CHANGE-ME-generate-a-real-key-before-running


# Site URL — used when building absolute URLs in emails (no trailing slash).
# Production: https:// because Cloudflare provides SSL to end users.
# Development: http://localhost:8000
#
SITE_URL=https://boardgames.tendimensions.com


# Comma-separated list of hostnames Django will accept requests for.
# Production: just the public domain (no localhost)
# Development: localhost,127.0.0.1
#
ALLOWED_HOSTS=boardgames.tendimensions.com


# =============================================================================
# SECTION 2 — Variables handled by docker-compose.yml  (DO NOT SET IN .env)
# =============================================================================
#
# The following are already hardcoded in docker-compose.yml and will override
# anything set here. Do not duplicate them in your production .env:
#
#   ENV=production          — disables DEBUG, enables security headers
#   DB_PATH=/app/data/db.sqlite3  — volume-mounted SQLite database
#
# For LOCAL development (web/.env only), you may set:
#   ENV=development
#   DB_PATH=                ← leave blank; defaults to web/db.sqlite3


# =============================================================================
# SECTION 3 — Microsoft Graph Email  (REQUIRED for account verification emails)
# =============================================================================
#
# The app sends email via Microsoft Graph API using an Entra ID (Azure AD)
# app registration with client credentials (app-only auth). This avoids the
# need to enable legacy SMTP AUTH on any mailbox.
#
# ONE-TIME AZURE SETUP (admin required)
# -------------------------------------------------------
# 1. Go to portal.azure.com → Entra ID → App registrations → New registration
#    Name: "Board Game Catalog Mailer"  (or any name)
#    Supported account types: "Accounts in this organizational directory only"
#    → Register
#
# 2. Note the "Application (client) ID" → MS_GRAPH_CLIENT_ID below
#    Note the "Directory (tenant) ID"   → MS_GRAPH_TENANT_ID below
#
# 3. API permissions → Add a permission → Microsoft Graph → Application permissions
#    Search for and add: Mail.Send
#    → Grant admin consent for tendimensions.com  (button at top of the permissions page)
#
# 4. Certificates & secrets → New client secret
#    Set an expiry (12 or 24 months recommended; you must rotate it before it expires)
#    Copy the Value immediately — it is only shown once → MS_GRAPH_CLIENT_SECRET below
#
# 5. MS_GRAPH_SENDER must be the full email address of a licensed Exchange Online
#    mailbox in your tenant (e.g. noreply@tendimensions.com).
#    The mailbox does NOT need SMTP AUTH enabled — Graph API bypasses that entirely.
#
# Secret rotation reminder: calendar an alert for before the secret expiry date.
# A new secret can be created before the old one expires; update .env and restart
# the container with: docker compose restart
#
MS_GRAPH_TENANT_ID=CHANGE-ME-your-entra-tenant-id
MS_GRAPH_CLIENT_ID=CHANGE-ME-your-app-registration-client-id
MS_GRAPH_CLIENT_SECRET=CHANGE-ME-your-client-secret-value
MS_GRAPH_SENDER=noreply@tendimensions.com


# =============================================================================
# SECTION 4 — External APIs
# =============================================================================

# BoardGameGeek XML API v2
#   BGG now requires a registered application token for all API access.
#   Register your application at: https://boardgamegeek.com/using_the_xml_api
#   Leave blank during development while awaiting approval; sync will be
#   unavailable until the token is set.
#
BGG_API_TOKEN=CHANGE-ME-your-bgg-api-token


# GameUPC.com API
#   Free and open; no authentication needed.
#   Used for barcode → board game lookup from the mobile app.
#   Endpoint: https://www.gameupc.com/api/v1/
#
# No key required for GameUPC.
